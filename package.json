{
  "name": "force-continue",
  "version": "1.0.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/dtg01100/opencode-force-continue.git"
  },
  "main": "force-continue.server.js",
  "bin": {
    "force-continue": "./scripts/setup-opencode.mjs"
  },
  "files": [
    "src/",
    "scripts/setup-opencode.mjs",
    "force-continue.server.js",
    "force-continue.tui.js"
  ],
  "exports": {
    ".": {
      "import": "./force-continue.server.js"
    },
    "./server": {
      "import": "./force-continue.server.js"
    },
    "./tui": {
      "import": "./force-continue.tui.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.mjs",
    "test:integration:watch": "vitest --config vitest.config.integration.mjs",
    "setup:local": "node ./scripts/setup-opencode.mjs",
    "setup:global": "node ./scripts/setup-opencode.mjs --global"
  },
  "devDependencies": {
    "vitest": "^4.1.2",
    "typescript": "^5.1.6",
    "@types/node": "^18.16.19"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.17"
  }
}
