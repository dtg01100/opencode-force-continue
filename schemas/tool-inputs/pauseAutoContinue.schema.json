{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PauseAutoContinueInput",
  "description": "Input schema for the pauseAutoContinue tool",
  "type": "object",
  "properties": {
    "reason": {
      "type": "string",
      "description": "Reason for pausing auto-continue"
    },
    "estimatedTime": {
      "type": "string",
      "description": "Estimated time until resumption"
    }
  },
  "required": ["reason"],
  "additionalProperties": false
}
